# P204 Server - Environment Variables
# Copy file này thành .env và điều chỉnh giá trị

# JWT Secret Key (tạo ngẫu nhiên: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=change_me_to_random_32_byte_hex

# Admin credentials
ADMIN_USER=admin
ADMIN_PASS=change_me_to_strong_password

# Server port
PORT=3000

# Allowed CORS origin (để * cho dev, đổi thành domain thật cho production)
CORS_ORIGIN=*

# SQLite database path
DB_PATH=./data/p204.db
